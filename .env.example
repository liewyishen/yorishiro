# Copy to .env and fill in. .env is gitignored — secrets never leave the machine.

# OpenRouter (L1/L2 model access)
OPENROUTER_API_KEY=sk-or-...

# Conversation DB password. The SAME value is read by docker-compose.yml (to
# initialise Postgres) and by the daemon (to connect). Any value works — this
# DB is single-user and localhost-only. If unset, the daemon still runs; it
# just has no short-term memory until the DB is reachable.
YORISHIRO_DB_PASSWORD=change-me
